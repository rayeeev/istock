# Ignore everything by default
/*

# Whitelist production-ready files and folders
!/.next/
!/public/
!/package.json
!/package-lock.json
!/server.js
!/.gitignore

# Keep ignoring environment variables for safety (manual upload recommended)
.env*

# Never push node_modules to GitHub (use cPanel to install)
/node_modules
/.pnp
.pnp.*